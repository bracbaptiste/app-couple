# Supabase — copier ce fichier en `.env.local` et renseigner les valeurs.
# Tableau de bord : Project Settings > API (https://supabase.com/dashboard).
#
# ⚠️ Seules des clés PUBLIQUES (anon) doivent figurer ici.
# Ne JAMAIS exposer la clé `service_role` côté client / dans un fichier versionné.

# URL du projet Supabase (ex. https://xxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE-PROJET.supabase.co

# Clé publique « anon » (sûre côté navigateur, protégée par les RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=VOTRE_CLE_ANON_PUBLIQUE
